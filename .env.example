# Supabase browser client config. Use the anon/publishable key only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional future TURN relay. Leave false while Cloudflare is not configured.
VITE_ENABLE_CLOUDFLARE_TURN=false


# Firebase Cloud Messaging browser config.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_fcm_web_push_vapid_key

# Server-only Supabase Edge Function secrets. Never prefix these with VITE_.
# SUPABASE_URL and SUPABASE_ANON_KEY are provided automatically by hosted Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
APP_ORIGIN=http://localhost:5173

# Optional future Cloudflare Realtime TURN (server-only; unused while the flag above is false).
CLOUDFLARE_TURN_KEY_ID=your_turn_key_id
CLOUDFLARE_TURN_KEY_API_TOKEN=your_turn_key_api_token

# Optional future Cloudflare R2 S3 credentials (current chat media uses Supabase Storage).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET=aahat-private-media

# No VITE_TURN_USERNAME, VITE_TURN_CREDENTIAL, R2 secret, Cloudflare API token,
# or Supabase service-role key belongs in the browser environment.
